# PostgreSQL (Prisma)
DATABASE_URL=postgres://usuario:senha@host:5432/rbz?sslmode=disable

# MongoDB (usuários / auth)
MONGODB_URI=mongodb://usuario:senha@host:27017/RBZ-DB?authSource=admin

# JWT
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_REFRESH_SECRET=troque-por-outro-segredo-longo-e-aleatorio

# URLs públicas (CORS e links)
# Sem barra no final. Várias origens: separar por vírgula em CORS_ORIGINS
FRONTEND_URL=https://rbz-frontend.qyspkj.easypanel.host
CORS_ORIGINS=https://rbz-frontend.qyspkj.easypanel.host,http://localhost:3000
BACKEND_URL=https://rbz-backend.qyspkj.easypanel.host

# Porta interna do container
PORT=3001

# Opcional — API de consulta de CNPJ
CNPJ_API_URL=https://brasilapi.com.br/api/cnpj/v1
CNPJ_FALLBACK_API_URL=https://www.receitaws.com.br/v1/cnpj
